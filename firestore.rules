rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── predictions ────────────────────────────────────────────────────────────
    // Flat collection; doc ID is "{userId}_{matchId}".
    // Any signed-in user can read all predictions (needed for leaderboard).
    // Only the owner can write their own predictions.
    match /predictions/{predId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == request.resource.data.userId;
    }

    // ── users ──────────────────────────────────────────────────────────────────
    // Any signed-in user can read all profiles (needed for leaderboard avatars).
    // Only the owner can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── groups ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read groups (leaderboard Groups tab).
    // Any signed-in user can create or update a group.
    // (Members array is an array of objects; Firestore rules can't filter nested
    // fields in arrays, so membership enforcement lives in the app layer.)
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }

    // ── matches ────────────────────────────────────────────────────────────────
    // Public read (live score updates shown to all visitors).
    // Writes are admin-only (Cloud Functions use Admin SDK, bypass rules).
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // ── goalScorers ────────────────────────────────────────────────────────────
    // Public read; admin-only write.
    match /goalScorers/{scorerId} {
      allow read: if true;
      allow write: if false;
    }

    // ── tournamentPicks ────────────────────────────────────────────────────────
    // Any signed-in user can read (for leaderboard / group picks display).
    // Only the owner can write their own picks.
    match /tournamentPicks/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── tournament ────────────────────────────────────────────────────────────
    // Public read (settings doc used by the bracket view).
    // Admin-only write.
    match /tournament/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── fcmTokens ─────────────────────────────────────────────────────────────
    // Tokens are write-only from the client; Cloud Functions read them via
    // the Admin SDK (bypasses rules). No client reads needed.
    match /fcmTokens/{token} {
      allow read: if false;
      allow write: if request.auth != null;
    }
  }
}
